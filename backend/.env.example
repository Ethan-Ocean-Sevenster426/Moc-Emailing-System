# Copy this file to `.env` and fill in real values. Never commit the real .env.

# AWS SES (email sending)
AWS_SES_ACCESS_KEY_ID=your-access-key-id
AWS_SES_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SES_REGION=eu-west-1
AWS_SES_FROM_EMAIL=Your Name <sender@yourdomain.com>

# Django
DJANGO_SECRET_KEY=generate-a-new-50-char-random-string
DJANGO_DEBUG=True

# Public base URL of this backend (used to build opt-out / unsubscribe links in emails)
PUBLIC_BASE_URL=http://localhost:8000
