# Copy this file to `.env` and fill in real values. Never commit the real .env.

# AWS SES (email sending)
AWS_SES_ACCESS_KEY_ID=your-access-key-id
AWS_SES_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SES_REGION=eu-west-1
AWS_SES_FROM_EMAIL=Your Name <sender@yourdomain.com>

# Django
DJANGO_SECRET_KEY=generate-a-new-50-char-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,206.189.204.60
# Where the frontend is served (used for CORS + CSRF). Comma-separate multiple.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
FRONTEND_URL=https://your-domain.com

# MySQL database (required)
DB_NAME=moc_emailing
DB_USER=moc
DB_PASSWORD=your-mysql-password
DB_HOST=127.0.0.1
DB_PORT=3306

# Public base URL of this backend (used to build opt-out / unsubscribe links in emails)
PUBLIC_BASE_URL=https://your-domain.com
